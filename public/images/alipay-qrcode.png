<svg xmlns="http://www.w3.org/2000/svg" width="300" height="300" viewBox="0 0 300 300">
  <rect width="300" height="300" fill="#ffffff"/>
  <rect x="20" y="20" width="260" height="260" fill="#f8f9fa" stroke="#dee2e6" stroke-width="2"/>
  <g fill="#0d6efd">
    <!-- 简单的二维码图案 -->
    <rect x="40" y="40" width="40" height="40"/>
    <rect x="100" y="40" width="20" height="20"/>
    <rect x="140" y="40" width="40" height="40"/>
    <rect x="200" y="40" width="40" height="40"/>
    <rect x="40" y="100" width="20" height="20"/>
    <rect x="180" y="100" width="20" height="20"/>
    <rect x="40" y="140" width="40" height="40"/>
    <rect x="100" y="140" width="20" height="20"/>
    <rect x="140" y="140" width="20" height="20"/>
    <rect x="200" y="140" width="40" height="40"/>
    <rect x="180" y="160" width="20" height="20"/>
    <rect x="40" y="200" width="40" height="40"/>
    <rect x="100" y="200" width="20" height="20"/>
    <rect x="140" y="200" width="40" height="40"/>
    <rect x="200" y="200" width="40" height="40"/>
    <rect x="160" y="100" width="20" height="20"/>
  </g>
  <text x="150" y="160" font-family="Arial" font-size="16" text-anchor="middle" fill="#666">支付宝</text>
</svg>